+/**
+ * Generate a random 8-character hex nonce for content boundary markers.
+ */
+export function generateBoundaryNonce(): string {
+  return crypto.randomBytes(4).toString('hex');
+}
+
+/**
+ * Wrap content with boundary markers to prevent prompt injection.
+ * The nonce makes each boundary unique, so injected content can't
+ * forge a matching end boundary.
+ */
+export function wrapWithBoundary(content: string, nonce?: string): string {
+  const n = nonce ?? generateBoundaryNonce();
+  return `---PAGE-CONTENT-BEGIN-${n}---\n${content}\n---PAGE-CONTENT-END-${n}---`;
+}
