+/**
+ * Check if content boundary wrapping is enabled.
+ * Disabled by --no-boundary flag (env AGENT_BROWSER_NO_BOUNDARY=1) or command-level noBoundary.
+ */
+function shouldWrapBoundary(command?: { noBoundary?: boolean }): boolean {
+  if (command?.noBoundary) return false;
+  if (process.env.AGENT_BROWSER_NO_BOUNDARY === '1') return false;
+  return true;
+}
+
+/**
+ * Validate file path to prevent path traversal attacks.
+ * Only allows writing to: current working directory, /tmp, and home directory.
+ */
+function validateFilePath(filePath: string): string {
+  const resolved = path.resolve(filePath);
+  const cwd = process.cwd();
+  const allowedDirs = [cwd, os.tmpdir(), os.homedir()];
+  if (!allowedDirs.some(dir => resolved.startsWith(dir + path.sep) || resolved === dir)) {
+    throw new Error(
+      `File path "${filePath}" is outside allowed directories. ` +
+      `Allowed: current directory (${cwd}), ${os.tmpdir()}, ${os.homedir()}.`
+    );
+  }
+  return resolved;
+}
